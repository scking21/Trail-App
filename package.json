{
  "name": "trail-app",
  "version": "1.0.0",
  "description": "Blackrow Trails — offline-capable trail maps, 50-state directory, and trip planner. Native iOS & Android via Capacitor.",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"fs.rmSync('www',{recursive:true,force:true})\"",
    "copy": "cpx \"{index,privacy,terms}.html\" www && cpx \"{sw,geo,ar,billing,share}.js\" www && cpx \"vendor/**/*\" \"www/vendor\" && echo copied",
    "config:native": "bash scripts/apply-native-config.sh",
    "ios:bump": "bash scripts/bump-ios-build.sh",
    "test": "jest",
    "build": "npm run clean && npm run copy",
    "sync": "npm run build && cap sync",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "run:ios": "cap run ios",
    "run:android": "cap run android"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.21",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "cordova-plugin-purchase": "^13.17.2",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "cpx2": "^9.0.0",
    "jest": "^30.4.2"
  }
}
