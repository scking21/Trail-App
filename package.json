{
  "name": "trail-app",
  "version": "1.0.0",
  "description": "Trail App — offline-capable trail maps, 50-state directory, and trip planner. Native iOS & Android via Capacitor.",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "copy": "cpx \"index.html\" www && cpx \"sw.js\" www && cpx \"geo.js\" www && cpx \"ar.js\" www && echo copied",
    "config:native": "bash scripts/apply-native-config.sh",
    "ios:bump": "bash scripts/bump-ios-build.sh",
    "test": "jest",
    "build": "npm run copy",
    "sync": "npm run build && cap sync",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "run:ios": "cap run ios",
    "run:android": "cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/geolocation": "^6.0.1",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "cpx2": "^7.0.1",
    "jest": "^29.7.0"
  }
}
